{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "sort-algorithms",
  "compatibility_date": "2026-03-29",
  "workers_dev": false,
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    { "pattern": "sortalgorithms.com", "custom_domain": true }
  ]
}
